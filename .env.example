# ==========================================================================
# Nestor – environment variables
# Copy this file to .env and fill in your values.  NEVER commit .env itself.
# ==========================================================================

# ---------- Telegram -------------------------------------------------------
# Bot token from @BotFather (required)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram user IDs allowed to interact with the bot (required)
# ALLOWED_TELEGRAM_IDS=12345678,87654321

# ---------- Slack (Socket Mode) -------------------------------------------
# Slack bot token (xoxb-...) and app-level token (xapp-...) to enable Slack transport
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# Optional signing secret for future HTTP mode integrations
# SLACK_SIGNING_SECRET=...
# Comma-separated Slack user IDs allowed to interact with Nestor (required if Slack enabled)
# ALLOWED_SLACK_USER_IDS=U01234567,U07654321
# Optional channel allowlist (comma-separated channel IDs, e.g., C01ABC...,C02DEF...)
# If empty, only DMs are allowed unless you mention Nestor in an allowed channel.
# ALLOWED_SLACK_CHANNEL_IDS=
# In channels, require @mention unless it is a follow-up in an active thread
# SLACK_REQUIRE_MENTION=true
# SLACK_ALLOW_THREAD_FOLLOWUPS=true

# ---------- LLM provider ---------------------------------------------------
# "anthropic" (default) or "openai"
# LLM_PROVIDER=anthropic

# Model override (defaults: claude-sonnet-4-20250514 for anthropic, gpt-4o for openai)
# LLM_MODEL=claude-sonnet-4-20250514
# Fast tier model for quick/low-cost requests (defaults by provider)
# LLM_MODEL_FAST=claude-3-5-haiku-latest
# Deep tier model for complex planning/research (defaults by provider)
# LLM_MODEL_DEEP=claude-sonnet-4-20250514
# Optional per-channel model tier override JSON, e.g. {"C01ABC":"deep","C09XYZ":"fast"}
# CHANNEL_MODEL_OVERRIDES={}
# Enable bounded parallel research prefetch on complex research tasks
# ENABLE_PARALLEL_RESEARCH=true

# API keys – only the key for the chosen provider is required
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ---------- Google Calendar ------------------------------------------------
# Path to OAuth 2.0 client credentials JSON downloaded from Google Cloud Console
# GOOGLE_CREDENTIALS_FILE=credentials.json

# Path where the OAuth token will be cached after the first login
# GOOGLE_TOKEN_FILE=token.json

# Calendar ID to read/write events ("primary" = the user's main calendar)
# GOOGLE_CALENDAR_ID=primary

# ---------- Storage --------------------------------------------------------
# SQLite database path
# DATABASE_PATH=nestor.db

# ---------- SQLite Backup to Google Drive ---------------------------------
# Enable periodic DB backup upload to Google Drive
# DB_BACKUP_TO_DRIVE=true

# Backup cadence in hours (24 = once/day)
# DB_BACKUP_INTERVAL_HOURS=24

# Drive filename to upsert on each backup
# DB_BACKUP_FILENAME=nestor-backup-latest.sqlite3

# Optional Drive folder ID where backup file should live
# DB_BACKUP_DRIVE_FOLDER_ID=

# Whether to run one backup immediately on startup
# DB_BACKUP_ON_START=true

# On startup, restore local SQLite from Drive backup if local DB is missing
# DB_RESTORE_FROM_DRIVE=true

# Optional HMAC key for backup manifest signing/verification across VPS restores
# If set, restore requires a valid manifest signed with this key
# DB_BACKUP_HMAC_KEY=replace-with-a-long-random-secret

# ---------- Gmail (SMTP/IMAP) ----------------------------------------------
# Nestor's Gmail address
# GMAIL_ADDRESS=your-nestor-email@gmail.com

# App Password (NOT the regular password) — create at https://myaccount.google.com/apppasswords
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ---------- Timezone -------------------------------------------------------
# IANA timezone for calendar events and datetime display
# NESTOR_TIMEZONE=America/New_York

# ---------- Logging --------------------------------------------------------
# Python log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
